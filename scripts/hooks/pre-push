#!/bin/bash
# Git pre-push hook.
#
# When a push touches the AppleScript/IMAP connector, run the real-execution
# smoke suite (`make smoke`) before letting the push proceed. The connector's
# AppleScript paths are the one layer mocked unit tests structurally cannot
# cover (osascript -10000 property errors, record-vs-list result shapes,
# does-save-actually-write) — every such bug in 2026-05 shipped because no
# AppleScript ran in CI. This hook closes that gap.
#
# Behavior:
#   - Only fires when src/apple_mail_mcp/{mail_connector,imap_connector}.py
#     changed in the commits being pushed.
#   - `make smoke` SELF-SKIPS when Mail.app/account/credentials aren't
#     available, so this never blocks a push on a machine without the setup;
#     it only blocks when the smoke tests actually run and FAIL.
#
# Install: `make install-hooks` (symlinks this into .git/hooks/pre-push).

set -uo pipefail

CONNECTOR_RE='src/apple_mail_mcp/(mail_connector|imap_connector)\.py'
ZERO='0000000000000000000000000000000000000000'
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root" || exit 0

connector_changed=0

# stdin: <local_ref> <local_sha> <remote_ref> <remote_sha> per ref being pushed.
while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ "$local_sha" = "$ZERO" ] && continue   # branch deletion — nothing to test

    if [ "$remote_sha" = "$ZERO" ]; then
        # New branch on the remote: diff against its merge-base with origin/main
        # (fall back to the root commit if origin/main is unknown).
        base="$(git merge-base origin/main "$local_sha" 2>/dev/null)"
        if [ -z "$base" ]; then
            base="$(git rev-list --max-parents=0 "$local_sha" | tail -1)"
        fi
        range="$base..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    if git diff --name-only "$range" 2>/dev/null | grep -qE "$CONNECTOR_RE"; then
        connector_changed=1
    fi
done

if [ "$connector_changed" -ne 1 ]; then
    exit 0
fi

echo "[pre-push] connector AppleScript/IMAP code changed -> running smoke suite (make smoke)..."
if make smoke; then
    echo "[pre-push] smoke suite passed (or skipped — no live Mail.app)."
    exit 0
fi

echo "" >&2
echo "[pre-push] SMOKE SUITE FAILED — push blocked." >&2
echo "  The AppleScript/IMAP connector changed and a real round-trip failed." >&2
echo "  Debug with: make smoke" >&2
echo "  Override (NOT recommended) with: git push --no-verify" >&2
exit 1
